<idea-plugin>
    <id>com.doxr.intellij</id>
    <name>doxr</name>
    <vendor url="https://github.com/scriptogre/doxr">doxr</vendor>

    <description><![CDATA[
        Docstring cross-reference navigation for Python. Makes
        <code>[text][pkg.mod.Class]</code> (MkDocs) and
        <code>:class:`pkg.mod.Class`</code> (Sphinx) references in docstrings
        Ctrl+Clickable — just like import statements.
    ]]></description>

    <depends>com.intellij.modules.python</depends>

    <extensions defaultExtensionNs="com.intellij">
        <psi.referenceContributor
                language="Python"
                implementation="com.doxr.intellij.DoxrReferenceContributor"/>
        <annotator
                language="Python"
                implementationClass="com.doxr.intellij.DoxrAnnotator"/>
    </extensions>
</idea-plugin>
